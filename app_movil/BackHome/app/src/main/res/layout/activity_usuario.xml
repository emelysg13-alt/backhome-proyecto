<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E1E1E"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="🐾 Mis Reportes"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#E91E8C"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BackHome"
            android:textSize="12sp"
            android:textColor="#888888"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnCrearReporteUsuario"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="＋ Crear Nuevo Reporte"
        android:backgroundTint="#E91E8C"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_margin="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Historial de reportes"
        android:textSize="13sp"
        android:textColor="#888888"
        android:paddingStart="16dp"
        android:paddingBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMisReportes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"/>

</LinearLayout>