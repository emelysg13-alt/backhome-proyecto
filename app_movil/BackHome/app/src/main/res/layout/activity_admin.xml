<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E1E1E"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="🐾 Panel Admin"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#E91E8C"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BackHome"
            android:textSize="12sp"
            android:textColor="#888888"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnVerReportes"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="📋 Reportes"
            android:backgroundTint="#E91E8C"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnVerUsuarios"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="👥 Usuarios"
            android:backgroundTint="#2C2C2C"
            android:textColor="#E91E8C"
            android:textSize="13sp"
            android:layout_marginStart="6dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/etBusqueda"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:hint="🔍 Buscar..."
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:background="@drawable/bg_input"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnBuscar"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Buscar"
            android:backgroundTint="#C2185B"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnCrearReporte"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="＋ Crear Reporte"
        android:backgroundTint="#E91E8C"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerReportes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"/>

</LinearLayout>